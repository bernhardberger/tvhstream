#!/usr/bin/env python3
"""Validate the repository-local OpenCode/OpenChamber engineering harness."""

from __future__ import annotations

import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
CONFIG_PATH = ROOT / ".opencode/opencode.json"
REQUIRED_FILES = (
    "AGENTS.md",
    ".opencode/opencode.json",
    ".opencode/agents/android-appliance.md",
    ".opencode/agents/android-reviewer.md",
    ".opencode/skills/android-tv-device-testing/SKILL.md",
    ".opencode/skills/tvhstream-upstream-contribution/SKILL.md",
    ".opencode/commands/verify.md",
    ".opencode/commands/device-check.md",
    ".opencode/commands/upstream-review.md",
    "docs/ai-engineering-harness.md",
    "docs/test-device-credential-provisioning.md",
    "app/src/debug/AndroidManifest.xml",
    "app/src/debug/java/cz/preclikos/tvhstream/DebugApp.kt",
    "app/libs/native-dependencies.json",
    ".github/workflows/build.yml",
    "tools/verify",
    "tools/device",
    "tools/check-native-libs",
    "tools/tests/test_device.py",
)
SKILL_NAME = re.compile(r"^[a-z0-9]+(?:-[a-z0-9]+)*$")
PRIVATE_KEY = re.compile(r"-----BEGIN [A-Z ]*PRIVATE KEY-----")
PRIVATE_LAN_IP = re.compile(r"\b(?:10\.\d{1,3}|192\.168|172\.(?:1[6-9]|2\d|3[01]))(?:\.\d{1,3}){2}\b")


def frontmatter(path: Path) -> dict[str, str]:
    text = path.read_text(encoding="utf-8")
    if not text.startswith("---\n"):
        return {}
    values: dict[str, str] = {}
    for line in text.splitlines()[1:]:
        if line == "---":
            break
        if not line.startswith(" ") and ":" in line:
            key, value = line.split(":", 1)
            values[key.strip()] = value.strip().strip("'\"")
    return values


def main() -> int:
    errors: list[str] = []
    warnings: list[str] = []

    for relative in REQUIRED_FILES:
        if not (ROOT / relative).is_file():
            errors.append(f"missing required file: {relative}")

    try:
        config = json.loads(CONFIG_PATH.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        errors.append(f"invalid OpenCode JSON: {exc}")
        config = {}

    if config.get("$schema") != "https://opencode.ai/config.json":
        errors.append(".opencode/opencode.json must declare the official schema")
    if config.get("default_agent") != "android-appliance":
        errors.append("default_agent must be android-appliance")
    if config.get("share") != "disabled":
        errors.append("project session sharing must remain disabled")
    if config.get("subagent_depth") != 0:
        errors.append("automatic subagent depth must remain zero")
    if config.get("permission", {}).get("task") != "deny":
        errors.append("project task/subagent permission must remain denied")

    for path in sorted((ROOT / ".opencode/agents").glob("*.md")):
        metadata = frontmatter(path)
        if not metadata.get("description"):
            errors.append(f"{path.relative_to(ROOT)}: missing description")
        if metadata.get("mode") not in {"primary", "subagent", "all"}:
            errors.append(f"{path.relative_to(ROOT)}: invalid or missing mode")

    for path in sorted((ROOT / ".opencode/commands").glob("*.md")):
        metadata = frontmatter(path)
        if not metadata.get("description"):
            errors.append(f"{path.relative_to(ROOT)}: missing description")
        if not path.read_text(encoding="utf-8").split("---", 2)[-1].strip():
            errors.append(f"{path.relative_to(ROOT)}: missing command body")

    seen_skills: set[str] = set()
    for path in sorted((ROOT / ".opencode/skills").glob("*/SKILL.md")):
        metadata = frontmatter(path)
        name = metadata.get("name", "")
        relative = path.relative_to(ROOT)
        if name != path.parent.name:
            errors.append(f"{relative}: skill name must match its directory")
        if not SKILL_NAME.fullmatch(name):
            errors.append(f"{relative}: invalid skill name {name!r}")
        if not metadata.get("description"):
            errors.append(f"{relative}: missing description")
        if name in seen_skills:
            errors.append(f"duplicate skill name: {name}")
        seen_skills.add(name)

    harness_paths = [
        ROOT / "AGENTS.md",
        ROOT / "docs/ai-engineering-harness.md",
        ROOT / "docs/test-device-credential-provisioning.md",
        ROOT / ".tvhstream-device.example.json",
        *sorted((ROOT / ".opencode").rglob("*.md")),
        *sorted(
            path
            for path in (ROOT / "tools").rglob("*")
            if path.is_file() and "__pycache__" not in path.parts
        ),
    ]
    for path in harness_paths:
        if not path.is_file():
            continue
        text = path.read_text(encoding="utf-8")
        if PRIVATE_KEY.search(text):
            errors.append(f"{path.relative_to(ROOT)}: contains private-key material")
        if PRIVATE_LAN_IP.search(text):
            errors.append(f"{path.relative_to(ROOT)}: contains a private LAN address")

    try:
        device_example = json.loads(
            (ROOT / ".tvhstream-device.example.json").read_text(encoding="utf-8")
        )
    except (OSError, json.JSONDecodeError) as exc:
        errors.append(f"invalid device example JSON: {exc}")
        device_example = {}
    if device_example.get("role") != "production":
        errors.append("device example must default to the safe production role")
    if device_example.get("credential_file") != ".tvhstream-credentials.json":
        errors.append("device example must name the ignored local credential file")
    for key in ("expected_manufacturer", "expected_model"):
        if not device_example.get(key):
            errors.append(f"device example must include {key}")

    gitignore = (ROOT / ".gitignore").read_text(encoding="utf-8")
    if ".tvhstream-credentials.json" not in gitignore.splitlines():
        errors.append("default local credential file must be ignored")

    workflow_path = ROOT / ".github/workflows/build.yml"
    if workflow_path.is_file():
        workflow = workflow_path.read_text(encoding="utf-8")
        if "contents: read" not in workflow:
            errors.append("CI workflow must use read-only contents permission")
        if "./tools/verify" not in workflow:
            errors.append("CI workflow must run ./tools/verify")
        for line in workflow.splitlines():
            stripped = line.strip()
            if not stripped.startswith("uses:") or "@" not in stripped:
                continue
            reference = stripped.rsplit("@", 1)[1].split(maxsplit=1)[0]
            if not re.fullmatch(r"[0-9a-f]{40}", reference):
                errors.append(f"CI action is not pinned to a full SHA: {stripped}")

    forbidden_release_paths = (
        ".github/workflows/android-play.yml",
        ".github/workflows/github-release.yml",
        "fastlane/Appfile",
        "fastlane/Fastfile",
    )
    for relative in forbidden_release_paths:
        if (ROOT / relative).exists():
            errors.append(f"stale release automation must remain disabled: {relative}")

    opencode = shutil.which("opencode")
    if opencode:
        environment = os.environ.copy()
        environment["OPENCODE_PURE"] = "1"
        result = subprocess.run(
            [opencode, "debug", "config", "--pure"],
            cwd=ROOT,
            env=environment,
            text=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.PIPE,
            timeout=30,
            check=False,
        )
        if result.returncode != 0:
            detail = result.stderr.strip().splitlines()
            errors.append(
                "OpenCode rejected the project config"
                + (f": {detail[-1]}" if detail else "")
            )
    else:
        warnings.append("opencode not found; skipped live config parser check")

    for warning in warnings:
        print(f"warning: {warning}")
    for error in errors:
        print(f"error: {error}", file=sys.stderr)

    if errors:
        return 1
    print(
        "AI harness passed: config, agents, skills, commands, safety scan, "
        "and OpenCode parser"
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
