#!/usr/bin/env python3
"""Validate the repository-local OpenCode/OpenChamber engineering harness."""

from __future__ import annotations

import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
CONFIG_PATH = ROOT / ".opencode/opencode.json"
REQUIRED_FILES = (
    "AGENTS.md",
    ".opencode/opencode.json",
    ".opencode/agents/android-appliance.md",
    ".opencode/agents/android-reviewer.md",
    ".opencode/skills/android-tv-device-testing/SKILL.md",
    ".opencode/skills/tvhstream-upstream-contribution/SKILL.md",
    ".opencode/commands/verify.md",
    ".opencode/commands/device-check.md",
    ".opencode/commands/upstream-review.md",
    "docs/ai-engineering-harness.md",
    "tools/verify",
    "tools/device",
)
SKILL_NAME = re.compile(r"^[a-z0-9]+(?:-[a-z0-9]+)*$")
PRIVATE_KEY = re.compile(r"-----BEGIN [A-Z ]*PRIVATE KEY-----")
PRIVATE_LAN_IP = re.compile(r"\b(?:10\.\d{1,3}|192\.168|172\.(?:1[6-9]|2\d|3[01]))(?:\.\d{1,3}){2}\b")


def frontmatter(path: Path) -> dict[str, str]:
    text = path.read_text(encoding="utf-8")
    if not text.startswith("---\n"):
        return {}
    values: dict[str, str] = {}
    for line in text.splitlines()[1:]:
        if line == "---":
            break
        if not line.startswith(" ") and ":" in line:
            key, value = line.split(":", 1)
            values[key.strip()] = value.strip().strip("'\"")
    return values


def main() -> int:
    errors: list[str] = []
    warnings: list[str] = []

    for relative in REQUIRED_FILES:
        if not (ROOT / relative).is_file():
            errors.append(f"missing required file: {relative}")

    try:
        config = json.loads(CONFIG_PATH.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        errors.append(f"invalid OpenCode JSON: {exc}")
        config = {}

    if config.get("$schema") != "https://opencode.ai/config.json":
        errors.append(".opencode/opencode.json must declare the official schema")
    if config.get("default_agent") != "android-appliance":
        errors.append("default_agent must be android-appliance")
    if config.get("share") != "disabled":
        errors.append("project session sharing must remain disabled")
    if config.get("subagent_depth") != 0:
        errors.append("automatic subagent depth must remain zero")
    if config.get("permission", {}).get("task") != "deny":
        errors.append("project task/subagent permission must remain denied")

    for path in sorted((ROOT / ".opencode/agents").glob("*.md")):
        metadata = frontmatter(path)
        if not metadata.get("description"):
            errors.append(f"{path.relative_to(ROOT)}: missing description")
        if metadata.get("mode") not in {"primary", "subagent", "all"}:
            errors.append(f"{path.relative_to(ROOT)}: invalid or missing mode")

    seen_skills: set[str] = set()
    for path in sorted((ROOT / ".opencode/skills").glob("*/SKILL.md")):
        metadata = frontmatter(path)
        name = metadata.get("name", "")
        relative = path.relative_to(ROOT)
        if name != path.parent.name:
            errors.append(f"{relative}: skill name must match its directory")
        if not SKILL_NAME.fullmatch(name):
            errors.append(f"{relative}: invalid skill name {name!r}")
        if not metadata.get("description"):
            errors.append(f"{relative}: missing description")
        if name in seen_skills:
            errors.append(f"duplicate skill name: {name}")
        seen_skills.add(name)

    harness_paths = [
        ROOT / "AGENTS.md",
        ROOT / "docs/ai-engineering-harness.md",
        ROOT / ".tvhstream-device.example.json",
        *sorted((ROOT / ".opencode").rglob("*.md")),
        *sorted((ROOT / "tools").glob("*")),
    ]
    for path in harness_paths:
        if not path.is_file():
            continue
        text = path.read_text(encoding="utf-8")
        if PRIVATE_KEY.search(text):
            errors.append(f"{path.relative_to(ROOT)}: contains private-key material")
        if PRIVATE_LAN_IP.search(text):
            errors.append(f"{path.relative_to(ROOT)}: contains a private LAN address")

    opencode = shutil.which("opencode")
    if opencode:
        environment = os.environ.copy()
        environment["OPENCODE_PURE"] = "1"
        result = subprocess.run(
            [opencode, "debug", "config", "--pure"],
            cwd=ROOT,
            env=environment,
            text=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.PIPE,
            timeout=30,
            check=False,
        )
        if result.returncode != 0:
            detail = result.stderr.strip().splitlines()
            errors.append(
                "OpenCode rejected the project config"
                + (f": {detail[-1]}" if detail else "")
            )
    else:
        warnings.append("opencode not found; skipped live config parser check")

    for warning in warnings:
        print(f"warning: {warning}")
    for error in errors:
        print(f"error: {error}", file=sys.stderr)

    if errors:
        return 1
    print(
        "AI harness passed: config, agents, skills, commands, safety scan, "
        "and OpenCode parser"
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
